<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Checked (selected) state uses a pill-shaped rounded background -->
    <item android:drawable="@drawable/bottom_nav_item_checked" android:state_checked="true" />
    <!-- Pressed state shows a subtle pressed background -->
    <item android:drawable="@drawable/bottom_nav_item_pressed" android:state_pressed="true" />
    <!-- Default: transparent -->
    <item android:drawable="@android:color/transparent" />
</selector>