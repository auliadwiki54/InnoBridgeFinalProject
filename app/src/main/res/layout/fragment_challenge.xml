<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="24dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <androidx.appcompat.widget.SearchView
                    android:id="@+id/sv_challenges"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:iconifiedByDefault="false"
                    app:queryBackground="@android:color/transparent"
                    app:queryHint="Cari tantangan..." />
            </com.google.android.material.card.MaterialCardView>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:scrollbars="none"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:paddingTop="8dp"
                android:paddingBottom="12dp">

                <LinearLayout
                    android:id="@+id/layout_categories_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:paddingHorizontal="16dp"
                    android:gravity="bottom">

                    <!-- ALL / SEMUA KATEGORI -->
                    <LinearLayout
                        android:id="@+id/container_all"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginEnd="12dp"
                        android:clipChildren="false"
                        android:clipToPadding="false">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btn_kat_all"
                            android:layout_width="54dp"
                            android:layout_height="54dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            app:cardBackgroundColor="@color/white"
                            app:cardCornerRadius="27dp"
                            app:cardElevation="2dp"
                            app:strokeWidth="0dp">
                            <ImageView
                                android:id="@+id/iv_icon_all"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_innovation"
                                app:tint="@color/primary_blue" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:id="@+id/tv_desc_all"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:gravity="center"
                            android:text="Semua\nKategori"
                            android:textColor="@color/text_navy"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:visibility="visible" />
                    </LinearLayout>

                    <!-- SDG 7: Energi Bersih -->
                    <LinearLayout
                        android:id="@+id/container_sdg7"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginEnd="12dp"
                        android:clipChildren="false"
                        android:clipToPadding="false">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btn_kat_sdg7"
                            android:layout_width="54dp"
                            android:layout_height="54dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            app:cardBackgroundColor="@color/white"
                            app:cardCornerRadius="27dp"
                            app:cardElevation="2dp"
                            app:strokeWidth="0dp">
                            <ImageView
                                android:id="@+id/iv_icon_sdg7"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_innovation"
                                app:tint="#F9A825" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:id="@+id/tv_desc_sdg7"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:gravity="center"
                            android:text="SDG 7\n5 Tantangan"
                            android:textColor="@color/text_navy"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:visibility="visible" />
                    </LinearLayout>

                    <!-- SDG 9: Industri & Inovasi -->
                    <LinearLayout
                        android:id="@+id/container_sdg9"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginEnd="12dp"
                        android:clipChildren="false"
                        android:clipToPadding="false">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btn_kat_sdg9"
                            android:layout_width="54dp"
                            android:layout_height="54dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            app:cardBackgroundColor="@color/white"
                            app:cardCornerRadius="27dp"
                            app:cardElevation="2dp"
                            app:strokeWidth="0dp">
                            <ImageView
                                android:id="@+id/iv_icon_sdg9"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_innovation"
                                app:tint="#DD1367" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:id="@+id/tv_desc_sdg9"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:gravity="center"
                            android:text="SDG 9\n5 Tantangan"
                            android:textColor="@color/text_navy"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:visibility="visible" />
                    </LinearLayout>

                    <!-- SDG 11: Kota Berkelanjutan -->
                    <LinearLayout
                        android:id="@+id/container_sdg11"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginEnd="12dp"
                        android:clipChildren="false"
                        android:clipToPadding="false">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btn_kat_sdg11"
                            android:layout_width="54dp"
                            android:layout_height="54dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            app:cardBackgroundColor="@color/white"
                            app:cardCornerRadius="27dp"
                            app:cardElevation="2dp"
                            app:strokeWidth="0dp">
                            <ImageView
                                android:id="@+id/iv_icon_sdg11"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_innovation"
                                app:tint="#FD9D24" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:id="@+id/tv_desc_sdg11"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:gravity="center"
                            android:text="SDG 11\n5 Tantangan"
                            android:textColor="@color/text_navy"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:visibility="visible" />
                    </LinearLayout>

                    <!-- SDG 14: Ekosistem Laut -->
                    <LinearLayout
                        android:id="@+id/container_sdg14"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:clipChildren="false"
                        android:clipToPadding="false">

                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/btn_kat_sdg14"
                            android:layout_width="54dp"
                            android:layout_height="54dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            app:cardBackgroundColor="@color/white"
                            app:cardCornerRadius="27dp"
                            app:cardElevation="2dp"
                            app:strokeWidth="0dp">
                            <ImageView
                                android:id="@+id/iv_icon_sdg14"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_innovation"
                                app:tint="#00A6DD" />
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:id="@+id/tv_desc_sdg14"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:gravity="center"
                            android:text="SDG 14\n5 Tantangan"
                            android:textColor="@color/text_navy"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:visibility="visible" />
                    </LinearLayout>

                </LinearLayout>
            </HorizontalScrollView>
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="100dp">

            <TextView
                android:id="@+id/tv_popular_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="8dp"
                android:text="Tantangan Populer"
                android:textColor="@color/text_navy"
                android:textSize="18sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cv_popular_challenge"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardBackgroundColor="@color/secondary_blue"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tv_pop_company"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_badge"
                        android:backgroundTint="@color/white"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="4dp"
                        android:text="TechCorp"
                        android:textColor="@color/primary_blue"
                        android:textSize="10sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_innovation"
                        app:tint="@color/primary_blue"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        android:contentDescription="Trend Icon" />

                    <TextView
                        android:id="@+id/tv_pop_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="AI for Sustainable Energy Grids"
                        android:textColor="@color/text_navy"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_pop_company" />

                    <TextView
                        android:id="@+id/tv_pop_desc"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Develop algorithms to optimize power distribution..."
                        android:textColor="@color/text_grey"
                        android:textSize="12sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_pop_title" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="🕒 Rp 15.000.000"
                        android:textColor="@color/text_navy"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_pop_desc" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="8dp"
                android:text="Semua Tantangan"
                android:textColor="@color/text_navy"
                android:textSize="18sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_challenges"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_challenge" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>