<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFF">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="80dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Welcome Greeting -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Selamat Datang,"
                    android:textColor="@color/text_grey"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_user_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Inovator"
                    android:textColor="@color/text_navy"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:ellipsize="end"
                    android:maxLines="1" />
            </LinearLayout>

            <!-- Header: Search Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp">

                <!-- Slim Search Bar -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:layout_marginTop="4dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:strokeColor="#E5E7EB"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="14dp">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_search"
                            app:tint="@color/text_light_grey" />

                        <EditText
                            android:id="@+id/et_search"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="Cari topik, perusahaan, atau kategori..."
                            android:textColor="@color/text_navy"
                            android:textColorHint="@color/text_light_grey"
                            android:textSize="13sp"
                            android:layout_marginStart="8dp"
                            android:singleLine="true"
                            android:imeOptions="actionSearch" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- Spanduk Promo Banner -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="8dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="145dp">

                    <!-- Blue Curved Banner Background -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@color/primary_blue" />

                    <!-- Content Layout -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="220dp"
                            android:layout_height="wrap_content"
                            android:text="Penelitianmu Dapat Membantu Banyak Orang!"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:lineSpacingExtra="3dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_ikuti_tantangan"
                            style="@style/Widget.Material3.Button.ElevatedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:backgroundTint="@color/white"
                            android:textColor="@color/primary_blue"
                            android:text="Ikuti Tantangan"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textAllCaps="false"
                            android:paddingHorizontal="16dp"
                            android:paddingVertical="8dp"
                            app:cornerRadius="12dp" />
                    </LinearLayout>
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Kategori SDG Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="24dp"
                android:clipChildren="false"
                android:clipToPadding="false">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:text="Kategori"
                    android:textColor="@color/text_navy"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:scrollbars="none"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:paddingBottom="12dp">

                    <LinearLayout
                        android:id="@+id/layout_categories_container"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:clipChildren="false"
                        android:clipToPadding="false"
                        android:paddingHorizontal="20dp"
                        android:gravity="bottom">

                        <!-- SDG 7: Energi Bersih -->
                        <LinearLayout
                            android:id="@+id/container_sdg7"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:layout_marginEnd="16dp"
                            android:clipChildren="false"
                            android:clipToPadding="false">

                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/btn_kat_sdg7"
                                android:layout_width="54dp"
                                android:layout_height="54dp"
                                android:clickable="true"
                                android:focusable="true"
                                android:foreground="?attr/selectableItemBackground"
                                app:cardBackgroundColor="@color/white"
                                app:cardCornerRadius="27dp"
                                app:cardElevation="2dp"
                                app:strokeWidth="0dp">
                                <ImageView
                                    android:id="@+id/iv_icon_sdg7"
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_innovation"
                                    app:tint="#F9A825" />
                            </com.google.android.material.card.MaterialCardView>

                            <TextView
                                android:id="@+id/tv_desc_sdg7"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:gravity="center"
                                android:text="SDG 7\n5 Tantangan Aktif"
                                android:textColor="@color/text_navy"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:visibility="visible" />
                        </LinearLayout>

                        <!-- SDG 9: Industri & Inovasi -->
                        <LinearLayout
                            android:id="@+id/container_sdg9"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:layout_marginEnd="16dp"
                            android:clipChildren="false"
                            android:clipToPadding="false">

                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/btn_kat_sdg9"
                                android:layout_width="54dp"
                                android:layout_height="54dp"
                                android:clickable="true"
                                android:focusable="true"
                                android:foreground="?attr/selectableItemBackground"
                                app:cardBackgroundColor="@color/white"
                                app:cardCornerRadius="27dp"
                                app:cardElevation="2dp"
                                app:strokeWidth="0dp">
                                <ImageView
                                    android:id="@+id/iv_icon_sdg9"
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_innovation"
                                    app:tint="#DD1367" />
                            </com.google.android.material.card.MaterialCardView>

                            <TextView
                                android:id="@+id/tv_desc_sdg9"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:gravity="center"
                                android:text="SDG 9\n5 Tantangan"
                                android:textColor="@color/text_navy"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:visibility="visible" />
                        </LinearLayout>

                        <!-- SDG 11: Kota Berkelanjutan -->
                        <LinearLayout
                            android:id="@+id/container_sdg11"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:layout_marginEnd="16dp"
                            android:clipChildren="false"
                            android:clipToPadding="false">

                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/btn_kat_sdg11"
                                android:layout_width="54dp"
                                android:layout_height="54dp"
                                android:clickable="true"
                                android:focusable="true"
                                android:foreground="?attr/selectableItemBackground"
                                app:cardBackgroundColor="@color/white"
                                app:cardCornerRadius="27dp"
                                app:cardElevation="2dp"
                                app:strokeWidth="0dp">
                                <ImageView
                                    android:id="@+id/iv_icon_sdg11"
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_innovation"
                                    app:tint="#FD9D24" />
                            </com.google.android.material.card.MaterialCardView>

                            <TextView
                                android:id="@+id/tv_desc_sdg11"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:gravity="center"
                                android:text="SDG 11\n5 Tantangan"
                                android:textColor="@color/text_navy"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:visibility="visible" />
                        </LinearLayout>

                        <!-- SDG 14: Ekosistem Laut -->
                        <LinearLayout
                            android:id="@+id/container_sdg14"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:clipChildren="false"
                            android:clipToPadding="false">

                            <com.google.android.material.card.MaterialCardView
                                android:id="@+id/btn_kat_sdg14"
                                android:layout_width="54dp"
                                android:layout_height="54dp"
                                android:clickable="true"
                                android:focusable="true"
                                android:foreground="?attr/selectableItemBackground"
                                app:cardBackgroundColor="@color/white"
                                app:cardCornerRadius="27dp"
                                app:cardElevation="2dp"
                                app:strokeWidth="0dp">
                                <ImageView
                                    android:id="@+id/iv_icon_sdg14"
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_innovation"
                                    app:tint="#00A6DD" />
                            </com.google.android.material.card.MaterialCardView>

                            <TextView
                                android:id="@+id/tv_desc_sdg14"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:gravity="center"
                                android:text="SDG 14\n5 Tantangan"
                                android:textColor="@color/text_navy"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:visibility="visible" />
                        </LinearLayout>
                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>

            <!-- Rekomendasi Tantangan Section (Renamed to Tantangan Saya) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="20dp"
                android:paddingHorizontal="20dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tantangan Saya"
                        android:textColor="@color/text_navy"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_lihat_semua"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerInParent="true"
                        android:text="Semua →"
                        android:textColor="@color/primary_blue"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true" />
                </RelativeLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_challenges"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:nestedScrollingEnabled="false"
                    tools:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                    tools:spanCount="2"
                    tools:listitem="@layout/item_challenge" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>