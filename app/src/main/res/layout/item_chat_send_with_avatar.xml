<?xml version="1.0" encoding="utf-8"?>
<!-- Pesan KELUAR (dikirim user) → bubble di KANAN, avatar inisial di kanan -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="end"
    android:paddingStart="56dp"
    android:paddingEnd="12dp"
    android:paddingTop="3dp"
    android:paddingBottom="3dp">

    <!-- Konten bubble + nama -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end"
        android:layout_marginEnd="8dp">

        <!-- Nama pengirim (diri sendiri, di atas bubble) -->
        <TextView
            android:id="@+id/tvSenderName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/primary_blue"
            android:layout_marginBottom="2dp" />

        <!-- Bubble pesan -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_chat_send"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            android:minWidth="60dp">

            <TextView
                android:id="@+id/tvMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:lineSpacingExtra="2dp" />

            <TextView
                android:id="@+id/tvTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="2dp"
                android:textColor="#CCffffff"
                android:textSize="11sp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Avatar inisial bulat di kanan (seperti WA) -->
    <TextView
        android:id="@+id/tvSenderAvatar"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:layout_marginTop="2dp"
        android:gravity="center"
        android:textColor="@color/white"
        android:textSize="13sp"
        android:textStyle="bold"
        android:background="@drawable/bg_avatar_send" />

</LinearLayout>
