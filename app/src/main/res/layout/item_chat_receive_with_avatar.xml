<?xml version="1.0" encoding="utf-8"?>
<!-- Pesan MASUK (diterima) → bubble di KIRI, avatar inisial di kiri -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="start"
    android:paddingStart="12dp"
    android:paddingEnd="56dp"
    android:paddingTop="3dp"
    android:paddingBottom="3dp">

    <!-- Avatar inisial bulat di kiri -->
    <TextView
        android:id="@+id/tvAvatarInitial"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="18dp"
        android:gravity="center"
        android:textColor="@color/white"
        android:textSize="13sp"
        android:textStyle="bold"
        android:background="@drawable/bg_avatar_circle" />

    <!-- Konten bubble + nama -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Nama pengirim di atas bubble -->
        <TextView
            android:id="@+id/tvReceiverName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/primary_navy"
            android:layout_marginBottom="2dp" />

        <!-- Bubble pesan -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_chat_receive"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            android:minWidth="60dp">

            <TextView
                android:id="@+id/tvMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_navy"
                android:textSize="14sp"
                android:lineSpacingExtra="2dp" />

            <TextView
                android:id="@+id/tvTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="2dp"
                android:textColor="@color/text_light_grey"
                android:textSize="11sp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
